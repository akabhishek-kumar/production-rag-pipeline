# Get free key at console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Where Chroma stores embeddings on disk
PERSIST_DIR=./chroma_db

# Folder ingest.py reads documents from
DOCS_DIR=./docs

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
RETRIEVER_K=5

# Quality gates
GRADE_THRESHOLD=6
MAX_RETRIES=2
